NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_DATA_API_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Recommended: set `GEMINI_API_KEY` as a server-only variable in Vercel (do NOT use NEXT_PUBLIC_ prefix).
# If you currently have `NEXT_PUBLIC_GEMINI_API_KEY` in Vercel, this project will fall back to it,
# but you should rename it to `GEMINI_API_KEY` to avoid exposing the secret to clients.
GEMINI_API_KEY=
NEXT_PUBLIC_GEMINI_API_KEY=

# Elastic (example)
ELASTICSEARCH_URL=https://smart-tutor-eduagent-ai-f1dee3.es.europe-west4.gcp.elastic.cloud:443
# Vercel may contain either of these names; both are supported by the codebase.
ELASTICSEARCH_API_KEY=
ELASTIC_SEARCH_API_KEY=

# NOTE: For security, keep your Gemini API key only in server-side environment variables on Vercel.
